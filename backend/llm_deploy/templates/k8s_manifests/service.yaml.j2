apiVersion: v1
kind: Service
metadata:
  name: {{ service_name }}
  labels:
    app: {{ deployment_name }}
    managed-by: llm-deploy
spec:
  type: {{ service_type | default("ClusterIP") }}
  ports:
    - port: {{ port | default(8000) }}
      targetPort: {{ port | default(8000) }}
      protocol: TCP
      name: http
  selector:
    app: {{ deployment_name }}
